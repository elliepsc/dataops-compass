# LLM
OPENAI_API_KEY=your_openai_api_key_here
MODEL_NAME=gpt-4o-mini

# PostgreSQL
POSTGRES_DB=dataops_assistant
POSTGRES_USER=admin
POSTGRES_PASSWORD=adminpassword
POSTGRES_PORT=5432
POSTGRES_HOST=postgres

# Qdrant
QDRANT_HOST=qdrant
