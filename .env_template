COLLECTION_NAME=dataops_docs

# App
APP_PORT=5000
TZ=Europe/Paris
RUN_TIMEZONE_CHECK=0

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_SECRET_KEY=your_secret_key_here
